/*
  # Prevent clickjacking — nobody can embed this site in an iframe
  X-Frame-Options: DENY
  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff
  # Legacy XSS filter (old IE/Edge)
  X-XSS-Protection: 1; mode=block
  # Force HTTPS for 1 year, include subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # Limit referrer info sent to other sites
  Referrer-Policy: strict-origin-when-cross-origin
  # Disable unnecessary browser features
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), bluetooth=()
  # Content Security Policy — only allow resources from own domain
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'
  # SEO
  X-Robots-Tag: index, follow

# Block access to .git directory (extra safety for some hosts)
/.git/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# Block access to sensitive config files
/.env
  X-Robots-Tag: noindex
  Cache-Control: no-store
/package.json
  X-Robots-Tag: noindex
  Cache-Control: no-store
/package-lock.json
  X-Robots-Tag: noindex
  Cache-Control: no-store
